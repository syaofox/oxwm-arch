#!/bin/bash

usage() {
  cat <<EOF
用法: flatpak-install [选项]

选项:
  -i, --install    浏览并安装新 Flatpak 软件包（默认行为）
  -l, --list       查看已安装的 Flatpak 软件包
  -u, --updates    检查可用更新
  -r, --uninstall  浏览并卸载已安装的 Flatpak 软件包
  -h, --help       显示此帮助信息
EOF
  exit 0
}

# ---- fzf 通用配置 ----
fzf_common=(
  --preview-label-pos='bottom'
  --preview-window 'down:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --color 'pointer:green,marker:green'
)

# ---- 安装模式 ----
mode_install() {
  local fzf_args=(
    "${fzf_common[@]}"
    --multi
    --preview 'flatpak remote-info flathub {1} 2>/dev/null || flatpak info {1} 2>/dev/null'
    --header '使用 TAB 选择多个软件，按 Enter 开始安装'
  )

  local pkg_names
  pkg_names=$(flatpak remote-ls --app --columns=application 2>/dev/null | fzf "${fzf_args[@]}")

  if [[ -z $pkg_names ]]; then
    return
  fi

  echo -e "\n\033[1;34m准备安装以下软件包:\033[0m"
  echo "-----------------------------------"
  local i=1
  local pkgs_array=()
  mapfile -t pkgs_array <<< "$pkg_names"
  for pkg in "${pkgs_array[@]}"; do
    printf "%2d. \033[1;32m%s\033[0m\n" $((i++)) "$pkg"
  done
  echo "-----------------------------------"

  read -p "是否继续安装？ [Y/n] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Nn]$ ]]; then
    echo -e "\n\033[1;33m正在从 Flathub 安装，请稍候...\033[0m\n"
    flatpak install -y flathub "${pkgs_array[@]}"
    if [ $? -eq 0 ]; then
      echo -e "\n\033[1;32m✔ 所有软件包已成功安装！\033[0m"
    else
      echo -e "\n\033[1;31m✘ 安装过程中出现错误。\033[0m"
    fi
  else
    echo "操作已取消。"
  fi
}

# ---- 查看已安装 ----
mode_list() {
  local fzf_args=(
    "${fzf_common[@]}"
    --preview 'flatpak info {1} 2>/dev/null'
    --header 'Enter/ESC 退出 · 方向键/鼠标滚动浏览'
  )

  flatpak list --app --columns=application 2>/dev/null | \
    fzf "${fzf_args[@]}" > /dev/null
}

# ---- 检查更新 ----
mode_updates() {
  echo -e "\033[1;34m正在检查可用更新...\033[0m"

  local updates
  updates=$(flatpak remote-ls --updates --columns=application 2>/dev/null)

  if [[ -z $updates ]]; then
    echo -e "\033[1;32m✔ 所有 Flatpak 软件包已是最新。\033[0m"
    return
  fi

  local count
  count=$(echo "$updates" | wc -l)
  echo -e "\033[1;33m发现 $count 个软件包可以更新:\033[0m"
  echo "-----------------------------------"
  echo "$updates"
  echo "-----------------------------------"

  read -p "是否更新所有软件包？ [Y/n] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Nn]$ ]]; then
    echo -e "\n\033[1;33m正在更新，请稍候...\033[0m\n"
    flatpak update -y
    if [ $? -eq 0 ]; then
      echo -e "\n\033[1;32m✔ 所有软件包已更新！\033[0m"
    else
      echo -e "\n\033[1;31m✘ 更新过程中出现错误。\033[0m"
    fi
  else
    echo "操作已取消。"
  fi
}

# ---- 卸载模式 ----
mode_uninstall() {
  local fzf_args=(
    "${fzf_common[@]}"
    --multi
    --preview 'flatpak info {1} 2>/dev/null'
    --header '使用 TAB 选择多个软件，按 Enter 开始卸载'
  )

  local pkg_names
  pkg_names=$(flatpak list --app --columns=application 2>/dev/null | fzf "${fzf_args[@]}")

  if [[ -z $pkg_names ]]; then
    return
  fi

  echo -e "\n\033[1;31m准备卸载以下软件包:\033[0m"
  echo "-----------------------------------"
  local i=1
  local pkgs_array=()
  mapfile -t pkgs_array <<< "$pkg_names"
  for pkg in "${pkgs_array[@]}"; do
    printf "%2d. \033[1;33m%s\033[0m\n" $((i++)) "$pkg"
  done
  echo "-----------------------------------"

  read -p "是否继续卸载？ [Y/n] " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Nn]$ ]]; then
    echo -e "\n\033[1;33m正在卸载，请稍候...\033[0m\n"
    flatpak uninstall -y "${pkgs_array[@]}"
    if [ $? -eq 0 ]; then
      echo -e "\n\033[1;32m✔ 所有软件包已成功卸载！\033[0m"
      # 清理残余
      flatpak uninstall --unused -y 2>/dev/null
    else
      echo -e "\n\033[1;31m✘ 卸载过程中出现错误。\033[0m"
    fi
  else
    echo "操作已取消。"
  fi
}

# ---- 参数解析 ----
case "${1:-}" in
  -i|--install)  mode_install ;;
  -l|--list)     mode_list ;;
  -u|--updates)  mode_updates ;;
  -r|--uninstall) mode_uninstall ;;
  -h|--help)     usage ;;
  '')            mode_install ;;
  *)             echo -e "\033[1;31m未知参数: $1\033[0m"; usage ;;
esac
